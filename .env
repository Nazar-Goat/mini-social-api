ENVIRONMENT=DEV
APP_NAME=crocus_crm_backend
APP_PORT=8000
MAIN_DOMAIN=192.168.0.1
DOCKERIZED=0

# CORS (JSON format)

CORS_ALLOW_ORIGINS=["*"]

# Database
DB_POSTGRES_HOST=db
DB_POSTGRES_PORT=5432
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASS=postgres
DB_POSTGRES_NAME=mini_social_api_db

# REDIS

REDIS_HOST=redis_db
REDIS_PORT=6379
REDIS_PASS=redis123
REDIS_AUTH_DB=0
REDIS_THROTTLING_DB=1
REDIS_QUEUE_DB=2
REDIS_OTP_DB=3

SECRET_KEY=super_secret_dev_key_change_in_production
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=15
FAILED_LOGIN_ATTEMPTS=5
FAILED_LOGIN_ATTEMPTS_TIMEOUT=300

REFRESH_TTL_DAYS=7
ACCESS_TTL_MINUTES=15

# =========================
# COOKIES
# =========================
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

IS_LAX_COOKIE=true
IS_SECURE_COOKIE=true

# ВАЖНО: JSON формат
COOKIE_DOMAIN_LIST=["localhost","127.0.0.1"]

